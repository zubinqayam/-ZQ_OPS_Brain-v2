{
  "$schema": "../node_modules/@tauri-apps/cli/schema/capability.schema.json",
  "identifier": "default",
  "description": "Default capability for ZQ Ops Brain",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-title",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "shell:allow-open"
  ]
}
