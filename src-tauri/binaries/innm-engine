#!/usr/bin/env python3
"""
innm-engine – Sidecar entry-point for ZQ Ops Brain INNM-WOSDS engine.

This script is compiled/packaged as a binary by PyInstaller and placed in
src-tauri/binaries/ with the correct Tauri sidecar naming convention:
  innm-engine-x86_64-pc-windows-msvc.exe   (Windows)
  innm-engine-aarch64-linux-android         (Android)

Usage (internal – called by Tauri):
  The binary reads JSON commands from stdin and writes JSON responses to stdout.
  Each command is a single line:
    {"cmd":"load_woods","path":"/some/folder"}
    {"cmd":"query","message":"what is the deployment plan?"}
    {"cmd":"status"}
"""

import sys
import os

# Ensure the INNM_ENGINE package is importable when running as a sidecar
_here = os.path.dirname(os.path.abspath(__file__))
_engine_dir = os.path.join(_here, "..", "INNM_ENGINE")
if os.path.isdir(_engine_dir):
    sys.path.insert(0, _engine_dir)
else:
    # Packaged: modules are bundled alongside this binary
    sys.path.insert(0, _here)

from ibox_core import main  # noqa: E402

if __name__ == "__main__":
    main()
